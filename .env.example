# Base URL of the Go API server. Leave empty when the API is on the same origin.
# Example: https://api.tidalclock.example.com
VITE_API_URL=

# The URL this frontend is served from. Used so the Go backend knows where to
# redirect after magic-link auth. Set APP_URL to the same value on the backend.
# Example: https://app.tidalclock.example.com
VITE_APP_URL=http://localhost:5173
